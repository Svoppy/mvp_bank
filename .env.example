SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-another-long-random-string
JWT_ISSUER=mvp-bank-api
JWT_AUDIENCE=mvp-bank-clients
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
TRUST_PROXY_HEADERS=False

DB_ENGINE=postgresql
DB_NAME=mvp_bank
DB_USER=mvp_bank_user
DB_PASSWORD=strong_password_here
DB_HOST=127.0.0.1
DB_PORT=5432

# Recommended for production behind HTTPS:
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# For a local SQLite demo instead of PostgreSQL:
# DB_ENGINE=sqlite
# SQLITE_PATH=db.sqlite3
